mutate(
AGENCY.y = coalesce(AGENCY.y, AGENCY.x),
LONGITUDE.y = ifelse(AGENCY.y != "TRPA", LONGITUDE.x, LONGITUDE.y),
LATITUDE.y = ifelse(AGENCY.y != "TRPA", LATITUDE.x, LATITUDE.y),
