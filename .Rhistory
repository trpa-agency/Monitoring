install.packages("devtools")
library(devtools) #Have to load the library before using install_github function
install_github("SCCWRP/BMIMetrics")
install_github("SCCWRP/CSCI")
library(dplyr)
library(tidyverse)
library(devtools)
library(CSCI)
library(readxl)
bug_path <- "F:/Research and Analysis/Fisheries/Streams/Bioassessment/2019/BMI/2019 TRPA BMI ABA version analysis.xlsx"
station_path <- "F:/Research and Analysis/Fisheries/Streams/Bioassessment/California Stream Condition Index/California Stream Condition Index/2019_CSCI/2019_Metrics_Consolidated.csv"
#Location to save CSCI outputs
output_path_base <- "F:/Research and Analysis/Fisheries/Streams/Bioassessment/California Stream Condition Index/California Stream Condition Index/2019_CSCI/CSCI_files"
collection_year <- "2019" #year that you are processing the data for
#Load and format bug data
bug_metrics <- read_excel(bug_path, sheet = "Record file") %>%
mutate(
SampleID = paste(Sample.I.D., collection_year, sep = "_"),
Distinct = NA
) %>%
select(
StationCode = Sample.I.D.,
SampleID,
FinalID = Taxon,
LifeStageCode = Stage,
BAResult = Abundance,
Distinct
)
View(bug_metrics)
#Load and format station data
